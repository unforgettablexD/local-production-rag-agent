APP_NAME=local-production-rag-agent
ENVIRONMENT=local
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EVAL_MODEL=
OLLAMA_NUM_PREDICT=256
OLLAMA_EVAL_NUM_PREDICT=120
OLLAMA_EVAL_FAST_NUM_PREDICT=80
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=rag_chunks
QDRANT_VECTOR_SIZE=768
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.2
EVAL_DEFAULT_QUESTION_LIMIT=20
EVAL_FAST_QUESTION_LIMIT=8
LOG_LEVEL=INFO
